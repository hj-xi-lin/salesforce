    <assignments>
        <name>Set_Release_Fields</name>
        <label>Set Release Fields</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.OwnerId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Label.Lead_Gen_User_ID</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.Stage_ACM__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Label.Account_Lifecycle_Stage_Outbound</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.RecordTypeId</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Label.AccountRecordTypeID_Outbound</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>$Record.GTM_Motion_Alignment_Helper__c</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>fmlToggleGTMHelper</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <decisions>
        <name>Fallback_By_Loss_Reason</name>
        <label>Fallback By Loss Reason</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Set_Release_Fields</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Release (Default)</defaultConnectorLabel>
        <rules>
            <name>Fallback_Permanent_Loss</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Loss_Reason_Account__c</leftValueReference>
                <operator>StartsWith</operator>
                <rightValue>
                    <stringValue>Admin:</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Loss_Fields</targetReference>
            </connector>
            <label>Permanent Loss (Fallback)</label>
        </rules>
    </decisions>
    <decisions>
        <name>Route_By_Outcome</name>
        <label>Route By Outcome</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Fallback_By_Loss_Reason</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Fallback</defaultConnectorLabel>
        <rules>
            <name>Outcome_Permanent_Loss</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Disqualification_Outcome__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Permanent_Loss</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Loss_Fields</targetReference>
            </connector>
            <label>Permanent Loss</label>
        </rules>
        <rules>
            <name>Outcome_Release</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Disqualification_Outcome__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Release</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Set_Release_Fields</targetReference>
            </connector>
            <label>Release</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>fmlToggleGTMHelper</name>
        <dataType>Boolean</dataType>
        <expression>NOT({!$Record.GTM_Motion_Alignment_Helper__c})</expression>
    </formulas>
    <interviewLabel>Account Disqualification Approved {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Account Disqualification Approved</label>
    <processMetadataValues>
