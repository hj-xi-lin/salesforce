    <runInMode>SystemModeWithSharing</runInMode>
    <screens>
        <name>Screen_Approval_Error</name>
        <label>Fehler bei Genehmigungsanfrage</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <fields>
            <name>txtErrorMessage</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;color: rgb(194, 57, 52);&quot;&gt;Die Genehmigungsanfrage konnte nicht gesendet werden. Bitte kontaktiere deinen Admin.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;{!$Flow.FaultMessage}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Screen_Confirm_Details</name>
        <label>Details und Bestätigung</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>true</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Decision_Approval_Required</targetReference>
        </connector>
        <fields>
            <name>txtConfirmInfo</name>
            <fieldText>&lt;p&gt;&lt;b&gt;Gewählter Grund:&lt;/b&gt; {!ddReason}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Outcome:&lt;/b&gt; {!Get_Selected_Reason.Outcome__c}&lt;/p&gt;&lt;p&gt;&lt;b&gt;Genehmigung nötig:&lt;/b&gt; {!fmlIsApprovalFree}&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>txtMarket</name>
            <dataType>String</dataType>
            <fieldText>In welchem Markt ist der Account tätig?</fieldText>
            <fieldType>InputField</fieldType>
            <isRequired>false</isRequired>
            <visibilityRule>
                <conditionLogic>and</conditionLogic>
                <conditions>
                    <leftValueReference>Get_Selected_Reason.Requires_Market_Input__c</leftValueReference>
                    <operator>EqualTo</operator>
                    <rightValue>
                        <booleanValue>true</booleanValue>
                    </rightValue>
                </conditions>
            </visibilityRule>
        </fields>
        <fields>
            <name>txtDetail</name>
            <fieldText>Weitere Details (optional)</fieldText>
            <fieldType>LargeTextArea</fieldType>
            <isRequired>false</isRequired>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <screens>
        <name>Screen_Select_Reason</name>
        <label>Grund auswählen</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <allowBack>false</allowBack>
        <allowFinish>true</allowFinish>
        <allowPause>false</allowPause>
        <connector>
            <targetReference>Get_Selected_Reason</targetReference>
        </connector>
        <fields>
            <name>txtHeader</name>
            <fieldText>&lt;p&gt;&lt;span style=&quot;font-size: 16px; font-weight: bold;&quot;&gt;Account disqualifizieren: {!Get_Account_Data.Name}&lt;/span&gt;&lt;/p&gt;</fieldText>
            <fieldType>DisplayText</fieldType>
        </fields>
        <fields>
            <name>ddReason</name>
            <choiceReferences>drcReasons</choiceReferences>
            <dataType>String</dataType>
            <fieldText>Grund</fieldText>
            <fieldType>DropdownBox</fieldType>
            <isRequired>true</isRequired>
        </fields>
        <showFooter>true</showFooter>
        <showHeader>false</showHeader>
    </screens>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Get_Account_Data</targetReference>
        </connector>
    </start>
    <status>Draft</status>
    <variables>
        <name>recordId</name>
        <dataType>String</dataType>
        <isCollection>false</isCollection>
        <isInput>true</isInput>
        <isOutput>false</isOutput>
    </variables>
</Flow>
