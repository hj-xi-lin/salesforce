<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Submit_For_Approval</name>
        <label>Submit for Approval</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>submit</actionName>
        <actionType>submit</actionType>
        <faultConnector>
            <targetReference>Screen_Approval_Error</targetReference>
        </faultConnector>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>objectId</name>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>comment</name>
            <value>
                <elementReference>fmlDetailWithMarket</elementReference>
            </value>
        </inputParameters>
        <nameSegment>submit</nameSegment>
    </actionCalls>
    <apiVersion>66.0</apiVersion>
    <constants>
        <name>LeadGenId</name>
        <dataType>String</dataType>
        <value>
            <stringValue>0050Y00000333XsQAI</stringValue>
        </value>
    </constants>
    <constants>
        <name>RecordTypeIdDiscarded</name>
        <dataType>String</dataType>
        <value>
            <stringValue>0121v000000lUxJAAU</stringValue>
        </value>
    </constants>
    <constants>
        <name>RecordTypeIdOutbound</name>
        <dataType>String</dataType>
        <value>
            <stringValue>0121v000000lUxKAAU</stringValue>
        </value>
    </constants>
    <decisions>
        <name>Decision_Approval_Required</name>
        <label>Approval Required?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Account_For_Approval</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Needs Approval</defaultConnectorLabel>
        <rules>
            <name>Outcome_Approval_Free</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fmlIsApprovalFree</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Decision_Release_Or_Loss</targetReference>
            </connector>
            <label>Approval Free</label>
        </rules>
    </decisions>
    <decisions>
        <name>Decision_Release_Or_Loss</name>
        <label>Release or Permanent Loss?</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <defaultConnector>
            <targetReference>Update_Account_Loss_Immediate</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Permanent Loss</defaultConnectorLabel>
        <rules>
            <name>Outcome_Release</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>fmlIsRelease</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Account_Release_Immediate</targetReference>
            </connector>
            <label>Release</label>
        </rules>
    </decisions>
    <dynamicChoiceSets>
        <name>drcReasons</name>
        <dataType>String</dataType>
        <displayField>MasterLabel</displayField>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Is_Active__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <limit>50</limit>
        <object>Disqualification_Reason__mdt</object>
        <sortField>Sort_Order__c</sortField>
        <sortOrder>Asc</sortOrder>
        <valueField>Reason_Value__c</valueField>
    </dynamicChoiceSets>
    <environments>Default</environments>
    <formulas>
        <name>fmlConditionalMet</name>
        <dataType>Boolean</dataType>
        <expression>(ISBLANK({!Get_Account_Data.Days_Since_Last_Booking__c}) || {!Get_Account_Data.Days_Since_Last_Booking__c} &gt; 365) &amp;&amp; {!Get_Account_Data.Estimated_Wallet_Size__c} &lt; 50000</expression>
    </formulas>
    <formulas>
        <name>fmlDetailWithMarket</name>
        <dataType>String</dataType>
        <expression>IF(NOT(ISBLANK({!txtMarket})), &quot;Market: &quot; &amp; {!txtMarket} &amp; IF(NOT(ISBLANK({!txtDetail})), &quot; | &quot; &amp; {!txtDetail}, &quot;&quot;), {!txtDetail})</expression>
    </formulas>
    <formulas>
        <name>fmlIsApprovalFree</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!Get_Selected_Reason.Approval_Requirement__c}) = &quot;Never&quot; || (TEXT({!Get_Selected_Reason.Approval_Requirement__c}) = &quot;Conditional&quot; &amp;&amp; {!fmlConditionalMet})</expression>
    </formulas>
    <formulas>
        <name>fmlIsRelease</name>
        <dataType>Boolean</dataType>
        <expression>TEXT({!Get_Selected_Reason.Outcome__c}) = &quot;Release&quot;</expression>
    </formulas>
    <formulas>
        <name>fmlOutcomeText</name>
        <dataType>String</dataType>
        <expression>TEXT({!Get_Selected_Reason.Outcome__c})</expression>
    </formulas>
    <formulas>
        <name>fmlToggleGTMHelper</name>
        <dataType>Boolean</dataType>
        <expression>NOT({!Get_Account_Data.GTM_Motion_Alignment_Helper__c})</expression>
    </formulas>
    <interviewLabel>Account Disqualification Process v2 {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Account Disqualification Process</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>Flow</processType>
    <recordLookups>
        <name>Get_Account_Data</name>
        <label>Get Account Data</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Screen_Select_Reason</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Account</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordLookups>
        <name>Get_Selected_Reason</name>
        <label>Get Selected Reason</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignNullValuesIfNoRecordsFound>false</assignNullValuesIfNoRecordsFound>
        <connector>
            <targetReference>Screen_Confirm_Details</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Reason_Value__c</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>ddReason</elementReference>
            </value>
        </filters>
        <getFirstRecordOnly>true</getFirstRecordOnly>
        <object>Disqualification_Reason__mdt</object>
        <storeOutputAutomatically>true</storeOutputAutomatically>
    </recordLookups>
    <recordUpdates>
        <name>Update_Account_For_Approval</name>
        <label>Update Account (Prepare for Approval)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Submit_For_Approval</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Disqualification_Outcome__c</field>
            <value>
                <elementReference>fmlOutcomeText</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Identified_Service_Country__c</field>
            <value>
                <elementReference>txtMarket</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Loss_Reason_Account__c</field>
            <value>
                <elementReference>ddReason</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Loss_Reason_Detail_Account__c</field>
            <value>
                <elementReference>fmlDetailWithMarket</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Account_Loss_Immediate</name>
        <label>Update Account (Permanent Loss - Immediate)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Blacklist__c</field>
            <value>
                <elementReference>Get_Selected_Reason.Sets_Blacklist__c</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Disqualification_Outcome__c</field>
            <value>
                <stringValue>Permanent_Loss</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>GTM_Motion_Alignment_Helper__c</field>
            <value>
                <elementReference>fmlToggleGTMHelper</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Loss_Reason_Account__c</field>
            <value>
                <elementReference>ddReason</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Loss_Reason_Detail_Account__c</field>
            <value>
                <elementReference>fmlDetailWithMarket</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RecordTypeId</field>
            <value>
                <elementReference>RecordTypeIdDiscarded</elementReference>
            </value>
        </inputAssignments>
        <object>Account</object>
    </recordUpdates>
    <recordUpdates>
        <name>Update_Account_Release_Immediate</name>
        <label>Update Account (Release - Immediate)</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Id</field>
            <operator>EqualTo</operator>
            <value>
                <elementReference>recordId</elementReference>
            </value>
        </filters>
        <inputAssignments>
            <field>Disqualification_Outcome__c</field>
            <value>
                <stringValue>Release</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>GTM_Motion_Alignment_Helper__c</field>
            <value>
                <elementReference>fmlToggleGTMHelper</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Identified_Service_Country__c</field>
            <value>
                <elementReference>txtMarket</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Loss_Reason_Account__c</field>
            <value>
                <elementReference>ddReason</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>Loss_Reason_Detail_Account__c</field>
            <value>
                <elementReference>fmlDetailWithMarket</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>OwnerId</field>
            <value>
                <elementReference>LeadGenId</elementReference>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>RecordTypeId</field>
            <value>
                <elementReference>RecordTypeIdOutbound</elementReference>
