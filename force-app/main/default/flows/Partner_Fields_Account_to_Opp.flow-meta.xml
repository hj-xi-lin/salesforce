            </connector>
            <label>Has Contract</label>
        </rules>
    </decisions>
    <description>RO-2858, RO-2864 — On agency Opportunity creation, copies Partner fields from the ultimate parent Account. If contract expired (today &gt; Partner_Contract_End_Date__c), sets commission and threshold fields to 0. Only triggers for Agency record types.</description>
    <environments>Default</environments>
    <formulas>
        <name>frmContractExpired</name>
        <dataType>Boolean</dataType>
        <expression>AND(
    NOT(ISBLANK({!Get_Source_Account.Partner_Contract_End_Date__c})),
    {!$Flow.CurrentDate} &gt; {!Get_Source_Account.Partner_Contract_End_Date__c}
)</expression>
    </formulas>
    <formulas>
        <name>frmSourceAccountId</name>
        <dataType>String</dataType>
        <expression>IF(
    ISBLANK({!Get_Account.Ultimate_Parent_Account_Id__c}),
    {!$Record.AccountId},
    {!Get_Account.Ultimate_Parent_Account_Id__c}
)</expression>
    </formulas>
