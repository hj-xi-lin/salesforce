        <defaultConnectorLabel>No Contract</defaultConnectorLabel>
        <rules>
            <name>Has_Contract</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Source_Account.Partner_Contract_End_Date__c</leftValueReference>
                <operator>IsNull</operator>
